#!/bin/sh
# Auto-Bump der App-Version in index.html bei JEDEM Commit.
# Schema: vYYYY-MM-DD.N  (N zaehlt die Commits pro Tag hoch)
# Stellt sicher: kein Deploy ohne neue Version (Pages serviert von main).
set -e

# Tag-Definition (TAGS.md) durchsetzen — Commit abbrechen bei Verstoß.
if [ -f "tools/validate_tags.cjs" ]; then
  node tools/validate_tags.cjs
fi

# Karten-Illustrationen optimieren: abgelegte NN.png/.jpg -> NN.webp
if [ -f "tools/optimize_images.cjs" ]; then
  node tools/optimize_images.cjs
  git add img/cards/*.webp 2>/dev/null || true
fi

f="index.html"
[ -f "$f" ] || exit 0

today=$(date +%Y-%m-%d)

# Aktuelle datumsbasierte Version (falls vorhanden) auslesen
cur=$(sed -n 's/.*class="app-version">v\([0-9]\{4\}-[0-9]\{2\}-[0-9]\{2\}\)\.\([0-9][0-9]*\).*/\1 \2/p' "$f" | head -n1)
curdate=$(printf '%s' "$cur" | awk '{print $1}')
curnum=$(printf '%s' "$cur" | awk '{print $2}')

if [ "$curdate" = "$today" ] && [ -n "$curnum" ]; then
  newnum=$((curnum + 1))
else
  newnum=1
fi
newver="v${today}.${newnum}"

# Versionszeile ersetzen (migriert auch ein altes Format wie "v0.1.0 · 2026-06-07")
sed -i "s#\(class=\"app-version\">\)[^<]*#\1${newver}#" "$f"
git add "$f"
echo "pre-commit: App-Version -> ${newver}"
